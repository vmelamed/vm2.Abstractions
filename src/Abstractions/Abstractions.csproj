<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <RootNamespace>vm2.Abstractions</RootNamespace>
    </PropertyGroup>

    <PropertyGroup Label="NuGet">
        <PackageId>vm2.Abstractions</PackageId>
        <Title>vm2 Abstractions</Title>
        <Description>vThe m2.Abstractions package defines some common interfaces and some default providers: IClock, ITenant, ICurrentTenant, IValidatable, etc.</Description>
        <PackageTags>vm2 Abstractions library package</PackageTags>
        <PackageProjectUrl>https://github.com/vmelamed/vm2.Abstractions</PackageProjectUrl>
        <RepositoryUrl>https://github.com/vmelamed/vm2.Abstractions</RepositoryUrl>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <None Include="../../README.md" Pack="true" PackagePath="\">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <None Include="../../LICENSE" Pack="true" PackagePath="\">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <None Include="../../CHANGELOG.md" Pack="true" PackagePath="\">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

</Project>
